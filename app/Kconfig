mainmenu "Specialized Test Application"

menu "CAN bus configuration"

config APP_CAN_BITRATE
	int "CAN bitrate (bps)"
	default 500000

config APP_CAN_SAMPLE_POINT_PERMILLE
	int "CAN sample point (permille)"
	default 875

config APP_CAN_LOOPBACK
	bool "Enable CAN loopback mode"
	default y
	help
	  Required to validate RX/TX on native_sim without physical hardware.

config APP_CAN_RX_QUEUE_DEPTH
	int "CAN RX message queue depth"
	default 8

endmenu

menu "Periodic TX messages"

config APP_TX1_ID
	hex "TX1 CAN ID"
	default 0x100

config APP_TX1_PERIOD_MS
	int "TX1 period (ms)"
	default 1000

config APP_TX2_ID
	hex "TX2 CAN ID"
	default 0x101

config APP_TX2_PERIOD_MS
	int "TX2 period (ms)"
	default 500

config APP_TX3_ID
	hex "TX3 CAN ID"
	default 0x102

config APP_TX3_PERIOD_MS
	int "TX3 period (ms)"
	default 250

endmenu

menu "Optional triggers"

config APP_START_TRIGGER_ENABLE
	bool "Enable start trigger"
	default n

config APP_START_TRIGGER_ID
	hex "Start trigger CAN ID"
	default 0x200
	depends on APP_START_TRIGGER_ENABLE

config APP_STOP_TRIGGER_ENABLE
	bool "Enable stop trigger"
	default n

config APP_STOP_TRIGGER_ID
	hex "Stop trigger CAN ID"
	default 0x201
	depends on APP_STOP_TRIGGER_ENABLE

config APP_HELLO_TRIGGER_ENABLE
	bool "Enable hello trigger"
	default n

config APP_HELLO_TRIGGER_ID
	hex "Hello trigger CAN ID"
	default 0x202
	depends on APP_HELLO_TRIGGER_ENABLE

endmenu

source "Kconfig.zephyr"
